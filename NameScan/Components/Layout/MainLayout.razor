@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">NameScan</MudText>
        <MudSpacer />
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">MVP</MudChip>
    </MudAppBar>

    <MudMainContent Class="main-content">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
